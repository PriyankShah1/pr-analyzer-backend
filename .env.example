# GitHub API Configuration
# Get your personal access token from: https://github.com/settings/tokens
# Token should have: repo (full control of private repositories) scope
GITHUB_TOKEN=your_github_personal_access_token_here

# Server Configuration
PORT=3001

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.com
